<?xml version="1.0"?>
<!-- Capsule-collider coverage fixture: l1 carries a <capsule> collision (Z-aligned,
     radius 0.1, length 0.4 → core segment z in [-0.2, 0.2], tips at +/-0.3). The
     capsule is parsed as a CollisionShape::Capsule (a swept sphere), so l1 is now
     COVERED (NOT in dropped_collider_frames) and uncovered_frames() counts only
     the collider-less `base`. At q=0 the capsule core spans z in [-0.2, 0.2]
     centered at the world origin. -->
<robot name="collide_capsule">
  <link name="base"/>
  <link name="l1">
    <collision><origin xyz="0 0 0"/>
      <geometry><capsule radius="0.1" length="0.4"/></geometry></collision>
  </link>
  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/>
    <origin xyz="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.0" upper="3.0" effort="10" velocity="2"/>
  </joint>
</robot>
