<?xml version="1.0"?>
<!-- Exercises every collision-shape branch: a sphere on a movable link, a
     cylinder on a FIXED-welded link (its collider rides the folded frame), and a
     mesh link that must be SKIPPED (no inline loader → collision-free). Total
     parsed colliders = 2 (sphere + cylinder); the mesh contributes none. -->
<robot name="collide_shapes">
  <link name="base"/>
  <link name="l1">
    <collision><origin xyz="0 0 0"/>
      <geometry><sphere radius="0.1"/></geometry></collision>
  </link>
  <link name="l2">
    <collision><origin xyz="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.2"/></geometry></collision>
  </link>
  <link name="l3">
    <collision><origin xyz="0 0 0"/>
      <geometry><mesh filename="hand.stl"/></geometry></collision>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/>
    <origin xyz="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.0" upper="3.0" effort="10" velocity="2"/>
  </joint>
  <joint name="f1" type="fixed">
    <parent link="l1"/><child link="l2"/>
    <origin xyz="0 0 0.5"/>
  </joint>
  <joint name="f2" type="fixed">
    <parent link="l2"/><child link="l3"/>
    <origin xyz="0 0 0.3"/>
  </joint>
</robot>
