<?xml version="1.0"?>
<!-- Implausible-inertia zoo (A002 positives + one A001-via-negative-mass):
     - l1: diagonal (1, 1, 3) violates the rigid-body triangle inequality (1+1 < 3)
     - l2: mass -2 -> treated as ABSENT (A001; no geometry, so NOT auto-fixable)
     - l3: positive mass with an all-zero tensor
     - l4: diagonal (1, 1, 1) but ixy=2 -> a NEGATIVE principal moment; the raw
       diagonal looks fine, so this one proves the eigenvalue path catches what
       converter-dropped off-diagonal handling would miss
     Everything else (root inertial, joints, axes, limits) is healthy. -->
<robot name="doctor_bad_inertia">
  <link name="base">
    <inertial><origin xyz="0 0 0"/><mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <link name="l1">
    <inertial><origin xyz="0 0 0"/><mass value="1.0"/>
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="3"/></inertial>
  </link>
  <link name="l2">
    <inertial><origin xyz="0 0 0"/><mass value="-2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <link name="l3">
    <inertial><origin xyz="0 0 0"/><mass value="1.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
  </link>
  <link name="l4">
    <inertial><origin xyz="0 0 0"/><mass value="1.0"/>
      <inertia ixx="1" ixy="2" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/><origin xyz="0 0 0.1"/><axis xyz="0 0 1"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
  <joint name="j2" type="revolute">
    <parent link="l1"/><child link="l2"/><origin xyz="0 0 0.1"/><axis xyz="0 1 0"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
  <joint name="j3" type="revolute">
    <parent link="l2"/><child link="l3"/><origin xyz="0 0 0.1"/><axis xyz="1 0 0"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
  <joint name="j4" type="revolute">
    <parent link="l3"/><child link="l4"/><origin xyz="0 0 0.1"/><axis xyz="0 0 1"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
</robot>
