<?xml version="1.0"?>
<!-- The doctor's ONE all-healthy fixture: the shared NEGATIVE case for every
     check (diagnose must return ZERO findings), and it genuinely compiles with
     full inertia. Deliberately exercises the near-miss paths: a continuous
     joint without limits (exempt from A007), a VALID mimic (j4 -> j3), a
     prismatic joint, and unit_cube.stl referenced under TWO spellings that
     resolve to the SAME file (not a duplicate-basename hit). -->
<robot name="doctor_clean">
  <link name="base">
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
    <collision><origin xyz="0 0 0"/><geometry><box size="0.1 0.1 0.1"/></geometry></collision>
  </link>
  <link name="l1">
    <inertial><origin xyz="0 0 0.1"/><mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/></inertial>
    <visual><origin xyz="0 0 0.1"/><geometry><box size="0.05 0.05 0.2"/></geometry></visual>
    <collision><origin xyz="0 0 0.1"/><geometry><box size="0.05 0.05 0.2"/></geometry></collision>
  </link>
  <link name="l2">
    <inertial><origin xyz="0 0 0"/><mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><mesh filename="unit_cube.stl" scale="0.1 0.1 0.1"/></geometry></visual>
    <collision><geometry><mesh filename="unit_cube.stl" scale="0.1 0.1 0.1"/></geometry></collision>
  </link>
  <link name="l3">
    <inertial><origin xyz="0 0 0"/><mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <collision><geometry><mesh filename="./unit_cube.stl" scale="0.1 0.1 0.1"/></geometry></collision>
  </link>
  <link name="l4">
    <inertial><origin xyz="0 0 0"/><mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/></inertial>
    <collision><geometry><box size="0.02 0.02 0.05"/></geometry></collision>
  </link>
  <link name="l5">
    <inertial><origin xyz="0 0 0"/><mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/></inertial>
    <collision><geometry><sphere radius="0.03"/></geometry></collision>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/>
    <origin xyz="0 0 0.05"/><axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="2"/>
  </joint>
  <joint name="j2" type="continuous">
    <parent link="l1"/><child link="l2"/>
    <origin xyz="0 0 0.2"/><axis xyz="0 1 0"/>
  </joint>
  <joint name="j3" type="revolute">
    <parent link="l2"/><child link="l3"/>
    <origin xyz="0 0 0.1"/><axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="5" velocity="1"/>
  </joint>
  <joint name="j4" type="revolute">
    <parent link="l3"/><child link="l4"/>
    <origin xyz="0 0 0.1"/><axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="5" velocity="1"/>
    <mimic joint="j3" multiplier="-1"/>
  </joint>
  <joint name="j5" type="prismatic">
    <parent link="l4"/><child link="l5"/>
    <origin xyz="0 0 0.05"/><axis xyz="0 0 1"/>
    <limit lower="0" upper="0.1" effort="10" velocity="0.5"/>
  </joint>
</robot>
