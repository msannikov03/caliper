<?xml version="1.0"?>
<!-- Unresolvable meshes (A003), both roles on one link:
     - collision mesh missing/nope.stl -> ERROR (the collider is silently
       dropped; the finding must list the tried search paths)
     - visual mesh package://ghost_pkg/meshes/g.stl -> WARN (renderer falls
       back to a placeholder)
     l1 has BOTH a visual and a collision, so A005 stays quiet; inertials and
     the joint are healthy, so these two findings are the whole report. -->
<robot name="doctor_mesh_missing">
  <link name="base">
    <inertial><origin xyz="0 0 0"/><mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <link name="l1">
    <inertial><origin xyz="0 0 0"/><mass value="0.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
    <visual><geometry><mesh filename="package://ghost_pkg/meshes/g.stl"/></geometry></visual>
    <collision><geometry><mesh filename="missing/nope.stl"/></geometry></collision>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/><origin xyz="0 0 0.1"/><axis xyz="0 0 1"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
</robot>
