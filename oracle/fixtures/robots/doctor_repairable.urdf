<?xml version="1.0"?>
<!-- Every AUTO-FIXABLE defect in one file, for the repair round-trip test:
     - l1: NO <inertial>, but a 1 m^3 box collider at z=0.5   (A001 -> compute_inertials; also proves the origin offset lands in the COM)
     - l2: NO <inertial>, but a unit-cube MESH collider        (A001 via the divergence-theorem path)
     - j1: axis "0 0 2" (A009 -> normalize_axes) and NO <limit> (A007 -> inject_limits)
     - j2: <limit> without effort/velocity (A014 -> inject_limits; urdf-rs rejects this file as-is)
     - j3: degenerate range lower=upper=0 (A007 -> inject_limits)
     Expected diagnose: 3 errors (A001 x2, A014), 3 warnings (A007 x2, A009).
     After RepairOpts::all() the copy must compile with has_inertia and
     re-diagnose completely clean.
     NOTE: the repo's unit_cube.stl is a hull fixture with inconsistent winding;
     the repair tests stage this file into a temp dir next to a properly wound
     cube STL before integrating it. -->
<robot name="doctor_repairable">
  <link name="base">
    <inertial><origin xyz="0 0 0"/><mass value="2.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/></inertial>
  </link>
  <link name="l1">
    <collision><origin xyz="0 0 0.5"/><geometry><box size="1 1 1"/></geometry></collision>
  </link>
  <link name="l2">
    <collision><origin xyz="0 0 0"/><geometry><mesh filename="unit_cube.stl"/></geometry></collision>
  </link>
  <link name="l3">
    <inertial><origin xyz="0 0 0"/><mass value="0.4"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/></inertial>
    <collision><geometry><box size="0.05 0.05 0.05"/></geometry></collision>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/>
    <origin xyz="0 0 0.1"/><axis xyz="0 0 2"/>
  </joint>
  <joint name="j2" type="revolute">
    <parent link="l1"/><child link="l2"/>
    <origin xyz="0 0 1.0"/><axis xyz="0 0 1"/>
    <limit lower="-1" upper="1"/>
  </joint>
  <joint name="j3" type="revolute">
    <parent link="l2"/><child link="l3"/>
    <origin xyz="0 0 0.6"/><axis xyz="0 1 0"/>
    <limit lower="0" upper="0" effort="5" velocity="1"/>
  </joint>
</robot>
