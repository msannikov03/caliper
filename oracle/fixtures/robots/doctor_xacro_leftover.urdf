<?xml version="1.0"?>
<!-- A013 positive: a plain .urdf (NO xmlns:xacro) still carrying xacro
     constructs — a <xacro:property> element and a ${w} substitution token.
     This is the classic "unexpanded xacro renamed to .urdf" mistake: URDF
     parsers fail on the tags or silently misread the ${..} values. The A013
     Error must be the ONLY finding (the rest of the file is healthy). -->
<robot name="doctor_xacro_leftover">
  <xacro:property name="w" value="0.1"/>
  <link name="base">
    <inertial><origin xyz="0 0 0"/><mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <link name="l1">
    <inertial><origin xyz="0 0 0"/><mass value="0.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
    <collision><origin xyz="${w} 0 0"/><geometry><box size="0.1 0.1 0.1"/></geometry></collision>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/><origin xyz="0 0 0.1"/><axis xyz="0 0 1"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
</robot>
