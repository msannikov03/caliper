<?xml version="1.0"?>
<!-- A008 positive: j1's axis is "0 0 0" — its motion direction is undefined
     and caliper refuses to compile (CompileError::ZeroAxis). Everything else
     is healthy; this Error must be the ONLY finding. -->
<robot name="doctor_zero_axis">
  <link name="base">
    <inertial><origin xyz="0 0 0"/><mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <link name="l1">
    <inertial><origin xyz="0 0 0"/><mass value="0.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/><origin xyz="0 0 0.1"/><axis xyz="0 0 0"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>
</robot>
