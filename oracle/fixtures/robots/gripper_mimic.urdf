<?xml version="1.0"?>
<!-- Mimic-joint fixture: a 1-link arm with a mimicking wrist and a parallel
     gripper. Full space ndof=4 (arm, wrist, finger1, finger2); independent=2:
       * wrist   mimics arm     with multiplier=0.5  offset=0.1 (revolute case)
       * finger2 mimics finger1 with multiplier=-1.0 offset=0   (parallel gripper) -->
<robot name="gripper_mimic">
  <link name="base"/>
  <link name="upper_arm"/>
  <link name="palm"/>
  <link name="finger_l"/>
  <link name="finger_r"/>
  <joint name="arm" type="revolute">
    <parent link="base"/><child link="upper_arm"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="30" velocity="2"/>
  </joint>
  <joint name="wrist" type="revolute">
    <parent link="upper_arm"/><child link="palm"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.6" upper="1.6" effort="15" velocity="2"/>
    <mimic joint="arm" multiplier="0.5" offset="0.1"/>
  </joint>
  <joint name="finger1" type="prismatic">
    <parent link="palm"/><child link="finger_l"/>
    <origin xyz="0.08 0.02 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="0" upper="0.04" effort="10" velocity="0.5"/>
  </joint>
  <joint name="finger2" type="prismatic">
    <parent link="palm"/><child link="finger_r"/>
    <origin xyz="0.08 -0.02 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.04" upper="0" effort="10" velocity="0.5"/>
    <mimic joint="finger1" multiplier="-1.0"/>
  </joint>
</robot>
