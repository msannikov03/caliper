<?xml version="1.0"?>
<!-- 2-link planar arm (revolute about y, links stacked along z) with TIGHT,
     asymmetric joint limits, built for the at-joint-limit IK stress test.
     j2's range is deliberately narrow ([-0.5, 0.5]) so a target that is the FK
     image of q=[1.0, 0.5] is only matchable with j2 sitting EXACTLY on its upper
     limit — the solver must converge onto the boundary (clamped) without NaN or
     hang, and the returned q must respect the limits. Inertials are present so a
     dynamics backend can also load it; only kinematics is exercised here. -->
<robot name="limit_arm">
  <link name="base"/>

  <link name="l1">
    <inertial><origin xyz="0 0 0.15"/><mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.002"/></inertial>
  </link>
  <link name="l2">
    <inertial><origin xyz="0 0 0.15"/><mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.002"/></inertial>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="20" velocity="5"/>
  </joint>
  <joint name="j2" type="revolute">
    <parent link="l1"/><child link="l2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="20" velocity="5"/>
  </joint>
</robot>
