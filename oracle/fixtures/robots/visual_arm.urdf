<?xml version="1.0"?>
<!-- Exercises RENDER-ONLY <visual> parsing: box with an INLINE rgba material,
     cylinder referencing the NAMED top-level material, bare sphere (no material),
     a relative-path mesh with scale (visual_hand.stl, exists), a
     package://demo_pkg mesh (resolves via the ancestor search to
     ../demo_pkg/meshes/part.stl), and an UNRESOLVABLE mesh (ghost_missing.stl)
     that must be KEPT with path=None without failing compile. -->
<robot name="visual_arm">
  <material name="steel">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>

  <link name="base">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.2 0.2 0.1"/></geometry>
      <material name="base_red">
        <color rgba="0.9 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>
  <link name="l1">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <material name="steel"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.3"/>
      <geometry><sphere radius="0.05"/></geometry>
    </visual>
  </link>
  <link name="l2">
    <visual>
      <geometry><mesh filename="visual_hand.stl" scale="2 2 2"/></geometry>
    </visual>
    <visual>
      <geometry><mesh filename="package://demo_pkg/meshes/part.stl"/></geometry>
    </visual>
    <visual>
      <geometry><mesh filename="ghost_missing.stl"/></geometry>
    </visual>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/><child link="l1"/>
    <origin xyz="0 0 0.1"/><axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>
  <joint name="j2" type="revolute">
    <parent link="l1"/><child link="l2"/>
    <origin xyz="0 0 0.3"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>
</robot>
